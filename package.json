{
  "name": "iran-conflict-tracker",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "copy-cesium": "node -e \"const{cpSync,existsSync}=require('fs');const s='node_modules/cesium/Build/Cesium/';['Workers','ThirdParty','Assets','Widgets'].forEach(d=>{if(!existsSync('public/cesium/'+d))cpSync(s+d,'public/cesium/'+d,{recursive:true})})\"",
    "dev": "npm run copy-cesium && astro dev",
    "check": "astro check",
    "build": "npm run copy-cesium && astro build",
    "preview": "astro preview",
    "update-data": "tsx scripts/update-data.ts",
    "backfill": "tsx scripts/backfill.ts",
    "backfill-gaps": "tsx scripts/backfill-gaps.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/react": "^4.4.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.18.0",
    "cesium": "^1.139.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "resium": "^1.19.4",
    "satellite.js": "^6.0.2"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.3.3",
    "openai": "^6.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  }
}
