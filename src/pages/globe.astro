---
import BaseLayout from '../layouts/BaseLayout.astro';
import CesiumGlobe from '../components/islands/CesiumGlobe/CesiumGlobe';
import { mapPoints, mapLines, kpis, meta, timeline } from '../lib/data';
import { flattenTimelineEvents } from '../lib/timeline-utils';
import '../styles/globe.css';

const events = flattenTimelineEvents(timeline);
---

<BaseLayout title="3D Intelligence Globe — Iran Conflict Tracker">
  <a href="/iran-conflict-tracker/" class="globe-back-link">&larr; Dashboard</a>
  <CesiumGlobe client:only="react" points={mapPoints} lines={mapLines} kpis={kpis} meta={meta} events={events} />
</BaseLayout>
