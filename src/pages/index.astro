---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadAllTrackers } from '../lib/tracker-registry';
import { loadTrackerData } from '../lib/data';
import GlobeBackground from '../components/islands/GlobeBackground';
import TrackerDirectory from '../components/islands/TrackerDirectory';

const trackers = loadAllTrackers();
const nonDraft = trackers.filter(t => t.status !== 'draft');
const active = trackers.filter(t => t.status === 'active');
const liveTrackers = active.filter(t => t.temporal !== 'historical');
const historicalTrackers = active.filter(t => t.temporal === 'historical');
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

// Serialize tracker data for the TrackerDirectory island
const serializedTrackers = nonDraft.map(t => {
  let topKpis: Array<{ value: string; label: string }> = [];
  let dayCount = 0;
  let lastUpdated = t.startDate;
  let headline: string | undefined;

  try {
    const data = loadTrackerData(t.slug, t.eraLabel);
    topKpis = data.kpis.slice(0, 3);
    dayCount = data.meta.dayCount;
    lastUpdated = data.meta.lastUpdated;
    headline = data.meta.heroHeadline?.replace(/<[^>]+>/g, ' ').replace(/\s{2,}/g, ' ').trim();
  } catch {
    // Tracker may not have data yet — use config defaults
  }

  return {
    slug: t.slug,
    shortName: t.shortName,
    name: t.name,
    description: t.description,
    icon: t.icon,
    color: t.color,
    status: t.status,
    temporal: t.temporal,
    domain: t.domain,
    region: t.region,
    country: t.country,
    startDate: t.startDate,
    endDate: t.endDate,
    sections: t.sections,
    seriesId: t.series?.id,
    seriesName: t.series?.name,
    seriesOrder: t.series?.order,
    isHub: t.series?.isHub,
    mapEnabled: t.map?.enabled,
    globeEnabled: t.globe?.enabled,
    dayCount,
    lastUpdated,
    headline,
    topKpis,
  };
});

// Collect event locations for the globe background
const globeEvents = serializedTrackers.flatMap(t => {
  try {
    const data = loadTrackerData(t.slug);
    return (data.mapPoints || []).slice(0, 30).map((p: any) => ({ lat: p.lat, lon: p.lon }));
  } catch { return []; }
});
---
<BaseLayout title="Watchboard — Intelligence Dashboard Platform">
  <main class="ix">
    <!-- Classification banner -->
    <div class="classification-bar">
      <span>UNCLASSIFIED</span>
      <span class="sep">//</span>
      <span>OPEN SOURCE INTELLIGENCE</span>
      <span class="sep">//</span>
      <span>FOUO</span>
    </div>

    <!-- Hero -->
    <header class="ix-hero">
      <div class="grid-bg" aria-hidden="true"></div>
      <GlobeBackground events={globeEvents} client:idle />
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="pulse-dot"></span>
          <span>LIVE MONITORING PLATFORM</span>
        </div>
        <h1 class="hero-title">WATCH<span class="title-accent">BOARD</span></h1>
        <p class="hero-sub">Multi-source intelligence dashboards with verified data,<br class="hide-mobile" /> interactive theater maps, and contested claims tracking.</p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">{liveTrackers.length}</span>
            <span class="stat-label">Live Operations</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">{historicalTrackers.length}</span>
            <span class="stat-label">Historical</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">4</span>
            <span class="stat-label">Source Tiers</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">AI</span>
            <span class="stat-label">Nightly Updates</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Tracker directory (search + domain tabs + grouped cards) -->
    <section class="ix-directory">
      <TrackerDirectory trackers={serializedTrackers} basePath={basePath} client:load />
    </section>

    <!-- Footer -->
    <footer class="ix-footer">
      <div class="footer-row">
        <span>Watchboard v1.0</span>
        <span class="footer-sep">&middot;</span>
        <span>Astro + React + CesiumJS</span>
        <span class="footer-sep">&middot;</span>
        <a href="https://github.com/ArtemioPadilla/watchboard" target="_blank" rel="noopener noreferrer">GitHub</a>
        <span class="footer-sep">&middot;</span>
        <span>MIT</span>
        <span class="footer-sep">&middot;</span>
        <a href="https://artemiop.com/" target="_blank" rel="noopener noreferrer">artemiop.com</a>
      </div>
      <div class="footer-disclaimer">
        This platform aggregates publicly available information. It does not endorse any political position or narrative.
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  /* ─── Layout ─── */
  .ix {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  /* ─── Classification bar ─── */
  .classification-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1rem;
    background: rgba(46, 204, 113, 0.06);
    border-bottom: 1px solid rgba(46, 204, 113, 0.12);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--accent-green);
    text-transform: uppercase;
  }

  .classification-bar .sep {
    opacity: 0.3;
  }

  /* ─── Hero ─── */
  .ix-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: 4rem 1.5rem 3rem;
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(52, 152, 219, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(52, 152, 219, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 720px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background: var(--accent-green);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(46, 204, 113, 0.4);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.08em;
    margin: 0 0 1rem;
    line-height: 1;
  }

  .title-accent {
    background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
  }

  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(24, 27, 35, 0.6);
    backdrop-filter: blur(8px);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-divider {
    width: 1px;
    height: 28px;
    background: var(--border);
  }

  /* ─── Directory section ─── */
  .ix-directory {
    margin: 0 auto 3rem;
    max-width: 100%;
  }

  /* ─── Footer ─── */
  .ix-footer {
    max-width: 960px;
    margin: 2rem auto 0;
    padding: 1.25rem 1.5rem 2rem;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .footer-row {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .footer-row a {
    color: var(--accent-blue);
    text-decoration: none;
  }

  .footer-row a:hover {
    text-decoration: underline;
  }

  .footer-sep {
    color: var(--border-light);
  }

  .footer-disclaimer {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    color: var(--text-muted);
    opacity: 0.4;
    line-height: 1.5;
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .hero-title {
      font-size: 3rem;
      letter-spacing: 0.04em;
    }

    .hero-sub .hide-mobile { display: none; }

    .hero-stats {
      flex-direction: column;
      gap: 0.75rem;
      padding: 1rem;
    }

    .stat-divider {
      width: 40px;
      height: 1px;
    }

    .classification-bar {
      font-size: 0.48rem;
      gap: 0.3rem;
    }

    .ix-hero {
      min-height: 50vh;
      padding: 3rem 1rem 2rem;
    }

  }

  @media (max-width: 420px) {
    .hero-title { font-size: 2.4rem; }
  }
</style>
