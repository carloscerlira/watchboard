---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadAllTrackers } from '../lib/tracker-registry';
import { loadTrackerData } from '../lib/data';
import GlobeBackground from '../components/islands/GlobeBackground';

const trackers = loadAllTrackers();
const active = trackers.filter(t => t.status === 'active');
const liveTrackers = active.filter(t => t.temporal !== 'historical');
const historicalTrackers = active.filter(t => t.temporal === 'historical');
const archived = trackers.filter(t => t.status === 'archived');
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

// Load meta + kpis + map points for each active tracker
const trackerData = active.map(t => {
  const data = loadTrackerData(t.slug, t.eraLabel);
  const topKpis = data.kpis.slice(0, 3);
  const dayCount = data.meta.dayCount;
  const lastUpdated = data.meta.lastUpdated;
  const headline = data.meta.heroHeadline?.replace(/<[^>]+>/g, ' ').replace(/\s{2,}/g, ' ').trim();
  const mapPoints = data.mapPoints || [];
  return { config: t, meta: data.meta, topKpis, dayCount, lastUpdated, headline, mapPoints };
});

// Collect event locations for the globe background
const globeEvents = trackerData.flatMap(({ mapPoints }) =>
  mapPoints.slice(0, 30).map(p => ({ lat: p.lat, lon: p.lon }))
);

const now = new Date();
const utcStr = now.toISOString().replace('T', ' ').slice(0, 19) + 'Z';
---
<BaseLayout title="Watchboard — Intelligence Dashboard Platform">
  <main class="ix">
    <!-- Classification banner -->
    <div class="classification-bar">
      <span>UNCLASSIFIED</span>
      <span class="sep">//</span>
      <span>OPEN SOURCE INTELLIGENCE</span>
      <span class="sep">//</span>
      <span>FOUO</span>
    </div>

    <!-- Hero -->
    <header class="ix-hero">
      <div class="grid-bg" aria-hidden="true"></div>
      <GlobeBackground events={globeEvents} client:idle />
      <div class="hero-content">
        <div class="hero-eyebrow">
          <span class="pulse-dot"></span>
          <span>LIVE MONITORING PLATFORM</span>
        </div>
        <h1 class="hero-title">WATCH<span class="title-accent">BOARD</span></h1>
        <p class="hero-sub">Multi-source intelligence dashboards with verified data,<br class="hide-mobile" /> interactive theater maps, and contested claims tracking.</p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">{liveTrackers.length}</span>
            <span class="stat-label">Live Operations</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">{historicalTrackers.length}</span>
            <span class="stat-label">Historical</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">4</span>
            <span class="stat-label">Source Tiers</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">AI</span>
            <span class="stat-label">Nightly Updates</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Live operations -->
    {liveTrackers.length > 0 && (
      <section class="ix-section">
        <div class="section-header">
          <h2 class="section-label">
            <span class="label-icon live-icon">&#9673;</span>
            Live Operations
          </h2>
          <span class="section-timestamp">{utcStr}</span>
        </div>

        <div class="tracker-grid">
          {trackerData.filter(d => d.config.temporal !== 'historical').map(({ config: t, meta, topKpis, dayCount, lastUpdated, headline }) => {
            const updated = new Date(lastUpdated);
            const ageHrs = Math.floor((now.getTime() - updated.getTime()) / 3600000);
            const freshness = ageHrs < 24 ? 'fresh' : ageHrs < 48 ? 'recent' : 'stale';
            return (
              <a href={`${basePath}${t.slug}/`} class="tracker-card" style={`--card-accent: ${t.color || '#3498db'}`}>
                <div class="card-top">
                  <div class="card-ident">
                    <span class="card-icon">{t.icon || ''}</span>
                    <div class="card-titles">
                      <h3 class="card-name">{t.shortName}</h3>
                      <span class="card-dateline">DAY {dayCount}</span>
                    </div>
                  </div>
                  <div class={`card-status ${freshness}`}>
                    <span class="status-dot"></span>
                    <span>{freshness === 'fresh' ? 'LIVE' : freshness === 'recent' ? 'RECENT' : 'STALE'}</span>
                  </div>
                </div>

                {headline && (
                  <div class="card-headline">
                    <span class="headline-marker">&rsaquo;</span>
                    <span>{headline.length > 100 ? headline.slice(0, 100) + '...' : headline}</span>
                  </div>
                )}

                <p class="card-desc">{t.description}</p>

                {topKpis.length > 0 && (
                  <div class="card-kpis">
                    {topKpis.map(k => (
                      <div class="kpi-chip">
                        <span class="kpi-value">{k.value}</span>
                        <span class="kpi-label">{k.label}</span>
                      </div>
                    ))}
                  </div>
                )}

                <div class="card-footer">
                  <div class="card-features">
                    <span>{t.sections.length} sections</span>
                    {t.map?.enabled && <span>Map</span>}
                    {t.globe?.enabled && <span>3D Globe</span>}
                  </div>
                  <span class="card-updated">
                    {ageHrs < 1 ? 'Just now' : ageHrs < 24 ? `${ageHrs}h ago` : `${Math.floor(ageHrs / 24)}d ago`}
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- Historical trackers -->
    {historicalTrackers.length > 0 && (
      <section class="ix-section">
        <div class="section-header">
          <h2 class="section-label">
            <span class="label-icon hist-icon">&#9202;</span>
            Historical Analysis
          </h2>
        </div>

        <div class="tracker-grid">
          {trackerData.filter(d => d.config.temporal === 'historical').map(({ config: t, meta, topKpis, dayCount, lastUpdated, headline }) => {
            const updated = new Date(lastUpdated);
            const ageHrs = Math.floor((now.getTime() - updated.getTime()) / 3600000);
            return (
              <a href={`${basePath}${t.slug}/`} class="tracker-card historical" style={`--card-accent: ${t.color || '#3498db'}`}>
                <div class="card-top">
                  <div class="card-ident">
                    <span class="card-icon">{t.icon || ''}</span>
                    <div class="card-titles">
                      <h3 class="card-name">{t.shortName}</h3>
                      <span class="card-dateline">{t.startDate.slice(0, 4)}{t.endDate ? `\u2013${t.endDate.slice(0, 4)}` : '\u2013Present'}</span>
                    </div>
                  </div>
                  <div class="card-status historical-badge">
                    <span>HISTORICAL</span>
                  </div>
                </div>

                {headline && (
                  <div class="card-headline">
                    <span class="headline-marker">&rsaquo;</span>
                    <span>{headline.length > 100 ? headline.slice(0, 100) + '...' : headline}</span>
                  </div>
                )}

                <p class="card-desc">{t.description}</p>

                {topKpis.length > 0 && (
                  <div class="card-kpis">
                    {topKpis.map(k => (
                      <div class="kpi-chip">
                        <span class="kpi-value">{k.value}</span>
                        <span class="kpi-label">{k.label}</span>
                      </div>
                    ))}
                  </div>
                )}

                <div class="card-footer">
                  <div class="card-features">
                    <span>{t.sections.length} sections</span>
                    {t.map?.enabled && <span>Map</span>}
                    {t.globe?.enabled && <span>3D Globe</span>}
                  </div>
                  <span class="card-updated">
                    {ageHrs < 1 ? 'Just now' : ageHrs < 24 ? `${ageHrs}h ago` : `${Math.floor(ageHrs / 24)}d ago`}
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {archived.length > 0 && (
      <section class="ix-section">
        <div class="section-header">
          <h2 class="section-label">
            <span class="label-icon">&#9723;</span>
            Archived
          </h2>
        </div>
        <div class="tracker-grid">
          {archived.map(t => (
            <a href={`${basePath}${t.slug}/`} class="tracker-card archived" style={`--card-accent: ${t.color || '#6b7280'}`}>
              <div class="card-top">
                <div class="card-ident">
                  <span class="card-icon">{t.icon || ''}</span>
                  <h3 class="card-name">{t.shortName}</h3>
                </div>
                <div class="card-status stale">
                  <span>ARCHIVED</span>
                </div>
              </div>
              <p class="card-desc">{t.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Footer -->
    <footer class="ix-footer">
      <div class="footer-grid">
        <div class="footer-col">
          <span class="footer-label">Platform</span>
          <span>Watchboard v1.0</span>
        </div>
        <div class="footer-col">
          <span class="footer-label">Stack</span>
          <span>Astro + React + CesiumJS</span>
        </div>
        <div class="footer-col">
          <span class="footer-label">Source</span>
          <a href="https://github.com/ArtemioPadilla/watchboard" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
        <div class="footer-col">
          <span class="footer-label">License</span>
          <span>MIT</span>
        </div>
      </div>
      <div class="footer-about-links">
        {trackerData.map(({ config: t }) => (
          <a href={`${basePath}${t.slug}/about/`}>{t.shortName} — About &amp; Credits</a>
        ))}
      </div>
      <div class="footer-disclaimer">
        This platform aggregates publicly available information. It does not endorse any political position or narrative.
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  /* ─── Layout ─── */
  .ix {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  /* ─── Classification bar ─── */
  .classification-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1rem;
    background: rgba(46, 204, 113, 0.06);
    border-bottom: 1px solid rgba(46, 204, 113, 0.12);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--accent-green);
    text-transform: uppercase;
  }

  .classification-bar .sep {
    opacity: 0.3;
  }

  /* ─── Hero ─── */
  .ix-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: 4rem 1.5rem 3rem;
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(52, 152, 219, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(52, 152, 219, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 20%, transparent 70%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 720px;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background: var(--accent-green);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(46, 204, 113, 0.4);
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.08em;
    margin: 0 0 1rem;
    line-height: 1;
  }

  .title-accent {
    background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 2.5rem;
  }

  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(24, 27, 35, 0.6);
    backdrop-filter: blur(8px);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .stat-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-divider {
    width: 1px;
    height: 28px;
    background: var(--border);
  }

  /* ─── Sections ─── */
  .ix-section {
    max-width: 960px;
    margin: 0 auto 3rem;
    padding: 0 1.5rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin: 0;
  }

  .label-icon {
    font-size: 0.7rem;
  }

  .label-icon.live-icon {
    color: var(--accent-green);
  }

  .label-icon.hist-icon {
    color: var(--accent-amber);
  }

  .section-timestamp {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    color: var(--text-muted);
    opacity: 0.6;
  }

  /* ─── Tracker cards ─── */
  .tracker-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 1rem;
  }

  .tracker-card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: all 0.25s ease;
    overflow: hidden;
  }

  .tracker-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--card-accent);
    opacity: 0.7;
    transition: opacity 0.25s;
  }

  .tracker-card:hover {
    border-color: color-mix(in srgb, var(--card-accent) 40%, var(--border));
    background: var(--bg-card-hover);
    transform: translateY(-3px);
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.3),
      0 0 0 1px color-mix(in srgb, var(--card-accent) 15%, transparent);
  }

  .tracker-card:hover::before {
    opacity: 1;
  }

  .tracker-card.archived {
    opacity: 0.6;
  }

  /* Card top row */
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .card-ident {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .card-icon {
    font-size: 1.6rem;
    line-height: 1;
  }

  .card-titles {
    display: flex;
    flex-direction: column;
  }

  .card-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
  }

  .card-dateline {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    font-weight: 500;
    color: var(--card-accent);
    letter-spacing: 0.1em;
    margin-top: 0.15rem;
  }

  /* Status badge */
  .card-status {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.56rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.25rem 0.55rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  .card-status.fresh {
    background: rgba(46, 204, 113, 0.1);
    color: var(--accent-green);
    border: 1px solid rgba(46, 204, 113, 0.25);
  }

  .card-status.fresh .status-dot {
    width: 5px;
    height: 5px;
    background: var(--accent-green);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  .card-status.recent {
    background: rgba(243, 156, 18, 0.1);
    color: var(--accent-amber);
    border: 1px solid rgba(243, 156, 18, 0.25);
  }

  .card-status.stale {
    background: rgba(148, 152, 168, 0.1);
    color: var(--text-muted);
    border: 1px solid var(--border);
  }

  .card-status.historical-badge {
    background: rgba(243, 156, 18, 0.1);
    color: var(--accent-amber);
    border: 1px solid rgba(243, 156, 18, 0.25);
  }

  /* Headline flash */
  .card-headline {
    display: flex;
    gap: 0.4rem;
    padding: 0.5rem 0.65rem;
    background: rgba(231, 76, 60, 0.04);
    border-left: 2px solid var(--card-accent);
    border-radius: 0 4px 4px 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.45;
  }

  .headline-marker {
    color: var(--card-accent);
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Description */
  .card-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin: 0;
  }

  /* KPI chips */
  .card-kpis {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .kpi-chip {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.4rem 0.6rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 5px;
    min-width: 0;
  }

  .kpi-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .kpi-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.5rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100px;
  }

  /* Card footer */
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }

  .card-features {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-features span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.56rem;
    color: var(--text-muted);
    background: var(--bg-secondary);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    border: 1px solid var(--border);
  }

  .card-updated {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.56rem;
    color: var(--text-muted);
    opacity: 0.7;
  }

  /* ─── Footer ─── */
  .ix-footer {
    max-width: 960px;
    margin: 2rem auto 0;
    padding: 1.5rem 1.5rem 2.5rem;
    border-top: 1px solid var(--border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--text-muted);
  }

  .footer-label {
    font-size: 0.52rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    opacity: 0.5;
  }

  .footer-col a {
    color: var(--accent-blue);
    text-decoration: none;
  }

  .footer-col a:hover {
    text-decoration: underline;
  }

  .footer-about-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .footer-about-links a {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    color: var(--text-muted);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s, color 0.2s;
  }

  .footer-about-links a:hover {
    color: var(--accent-blue);
    opacity: 1;
  }

  .footer-disclaimer {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.68rem;
    color: var(--text-muted);
    opacity: 0.5;
    line-height: 1.5;
    text-align: center;
  }

  /* ─── Responsive ─── */
  @media (max-width: 640px) {
    .hero-title {
      font-size: 3rem;
      letter-spacing: 0.04em;
    }

    .hero-sub .hide-mobile { display: none; }

    .hero-stats {
      flex-direction: column;
      gap: 0.75rem;
      padding: 1rem;
    }

    .stat-divider {
      width: 40px;
      height: 1px;
    }

    .tracker-grid {
      grid-template-columns: 1fr;
    }

    .classification-bar {
      font-size: 0.48rem;
      gap: 0.3rem;
    }

    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }

