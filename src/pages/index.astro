---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadAllTrackers } from '../lib/tracker-registry';
import { loadTrackerData } from '../lib/data';
import CommandCenter from '../components/islands/CommandCenter/CommandCenter';

const trackers = loadAllTrackers();
const nonDraft = trackers.filter(t => t.status !== 'draft');
const active = trackers.filter(t => t.status === 'active');
const liveTrackers = active.filter(t => t.temporal !== 'historical');
const historicalTrackers = active.filter(t => t.temporal === 'historical');
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;

// Serialize tracker data for the CommandCenter island
const serializedTrackers = nonDraft.map(t => {
  let topKpis: Array<{ value: string; label: string }> = [];
  let dayCount = 0;
  let lastUpdated = t.startDate;
  let headline: string | undefined;

  try {
    const data = loadTrackerData(t.slug, t.eraLabel);
    topKpis = data.kpis.slice(0, 3);
    dayCount = data.meta.dayCount;
    lastUpdated = data.meta.lastUpdated;
    headline = data.meta.heroHeadline?.replace(/<[^>]+>/g, ' ').replace(/\s{2,}/g, ' ').trim();
  } catch {
    // Tracker may not have data yet — use config defaults
  }

  return {
    slug: t.slug,
    shortName: t.shortName,
    name: t.name,
    description: t.description,
    icon: t.icon,
    color: t.color,
    status: t.status,
    temporal: t.temporal,
    domain: t.domain,
    region: t.region,
    country: t.country,
    startDate: t.startDate,
    endDate: t.endDate,
    sections: t.sections,
    seriesId: t.series?.id,
    seriesName: t.series?.name,
    seriesOrder: t.series?.order,
    isHub: t.series?.isHub,
    mapEnabled: t.map?.enabled,
    globeEnabled: t.globe?.enabled,
    mapCenter: t.map?.center,
    dayCount,
    lastUpdated,
    headline,
    topKpis,
  };
});
---
<BaseLayout title="Watchboard — Intelligence Dashboard Platform">
  <CommandCenter
    trackers={serializedTrackers}
    basePath={basePath}
    liveCount={liveTrackers.length}
    historicalCount={historicalTrackers.length}
    client:load
  />
</BaseLayout>

<style is:global>
  /* Command center takes full viewport — remove body margins/scroll (home page only) */
  body:has(.command-center-root) {
    overflow: hidden;
  }

  /* Globe status text: swap for mobile-appropriate instructions */
  .globe-status-mobile { display: none; }

  @media (max-width: 767px) {
    .globe-status-desktop { display: none; }
    .globe-status-mobile { display: inline; }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Mobile: stack globe + sidebar vertically */
  @media (max-width: 767px) {
    .command-center-root {
      flex-direction: column !important;
      height: 100vh !important;
      height: 100dvh !important;
    }
    .command-center-root > div:first-child {
      flex: none !important;
      height: 28vh !important;
      min-height: 160px !important;
    }
    .command-center-root > div:last-child {
      flex: 1 !important;
      max-width: none !important;
      min-width: 0 !important;
      border-left: none !important;
      border-top: 1px solid var(--border) !important;
    }

    /* Sidebar header: larger touch targets */
    .command-center-root input[type="text"] {
      font-size: 16px !important; /* Prevents iOS zoom on focus */
      min-height: 40px !important;
      padding: 8px 10px 8px 32px !important;
    }

    /* Make tracker rows taller for touch */
    .command-center-root [style*="padding: 6px 12px"] {
      min-height: 48px !important;
    }

    /* Make domain filter tabs taller */
    .command-center-root button[type="button"] {
      min-height: 32px !important;
      padding: 6px 10px !important;
      font-size: 0.58rem !important;
    }

    /* Series strip: allow wrapping */
    .command-center-root [style*="overflowX"] {
      -webkit-overflow-scrolling: touch !important;
    }

    /* Open dashboard link: bigger tap target */
    .command-center-root a[href*="/"] {
      min-height: 32px !important;
      display: inline-flex !important;
      align-items: center !important;
    }
  }

  /* Hide globe entirely on very small screens to save resources */
  @media (max-width: 380px) {
    .command-center-root > div:first-child {
      height: 20vh !important;
      min-height: 120px !important;
    }
  }
</style>
