---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content="Comprehensive intelligence dashboard tracking the 2026 Iran-US/Israel conflict with sourced data, interactive map, and contested claims matrix.">
  <meta property="og:title" content="2026 Iran Conflict — Intelligence Dashboard">
  <meta property="og:description" content="Operation Epic Fury / Roaring Lion — live intelligence dashboard. Strike locations, casualties, economic impact, multi-pole sourcing, contested claims.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://artemiopadilla.github.io/iran-conflict-tracker/">
  <meta property="og:image" content="https://artemiopadilla.github.io/iran-conflict-tracker/og-card.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:image" content="https://artemiopadilla.github.io/iran-conflict-tracker/og-card.png">
  <meta name="theme-color" content="#0a0b0e">
  <link rel="canonical" href="https://artemiopadilla.github.io/iran-conflict-tracker/">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔴</text></svg>">
  <script is:inline type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "2026 Iran Conflict — Intelligence Dashboard",
    "description": "Comprehensive intelligence dashboard tracking the 2026 Iran-US/Israel conflict with sourced data, interactive map, and contested claims matrix.",
    "url": "https://artemiopadilla.github.io/iran-conflict-tracker/"
  }
  </script>
  <link rel="preload" as="font" type="font/woff2" crossorigin href="/iran-conflict-tracker/fonts/dm-sans-latin.woff2">
  <link rel="preload" as="font" type="font/woff2" crossorigin href="/iran-conflict-tracker/fonts/jetbrains-mono-latin.woff2">
</head>
<body>
  <div class="tooltip" id="tooltip"></div>
  <slot />

  <script>
    const observer = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</body>
</html>
